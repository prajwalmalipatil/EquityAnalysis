# ==============================================================================
# V² Money Quantitative Research Platform - Environment Variables Template
# Copy this file to '.env' and populate with your credentials.
# ==============================================================================

# 1. Google Gemini AI Enrichment (Required for Macro Intelligence enrichment)
# Obtain a key from the Google AI Studio: https://aistudio.google.com/
GOOGLE_API_KEY=your_google_gemini_api_key_here

# 2. Automated Email Notifier System (Optional/Required for daily email alerts)
# Note: For Gmail, you MUST generate an App Password rather than using your raw password:
# https://support.google.com/accounts/answer/185833
SENDER_EMAIL=sender_email_address@gmail.com
SENDER_PASSWORD=your_gmail_app_password_here
